const question = document.getElementById("question");
const yesBtn = document.getElementById("yesBtn");
const noBtn = document.getElementById("noBtn");

let step = 0;
let scale = 1;

// Questions flow (your exact steps)
const steps = [
  "Are you positive? 😢",
  "Pookie please 🥺",
  "If you say no I will be very sad 💔",
  "I will be very sad 😭",
  "Please????? 😳"
];

// YES → final screen
yesBtn.addEventListener("click", () => {
  document.body.innerHTML = `
    <div style="text-align:center;margin-top:100px;">
      <h1 style="color:white;font-size:50px;">YAYYYY 💖💖💖</h1>
      <img src="images/happy.gif" width="300">
    </div>
  `;
});

// NO CLICK FLOW
noBtn.addEventListener("click", () => {

  if (step < steps.length) {
    question.innerText = steps[step];
    step++;

    // Increase YES size
    scale += 0.3;
    yesBtn.style.transform = `scale(${scale})`;

  } else {
    // FINAL STEP → No runs away
    noBtn.addEventListener("mouseover", moveButton);
  }
});

// Move button function
function moveButton() {
  const x = Math.random() * (window.innerWidth - 120);
  const y = Math.random() * (window.innerHeight - 60);

  noBtn.style.left = x + "px";
  noBtn.style.top = y + "px";

  // Grow YES more
  scale += 0.2;
  yesBtn.style.transform = `scale(${scale})`;
}
